# ============================================================
# HR Nexus — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=HR Nexus
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# --- Database ---
# PostgreSQL (production — Render provides DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/hr_nexus

# --- Security ---
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
REFRESH_SECRET_KEY=your-refresh-secret-key-change-this-in-production-min-32-chars

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Add your Vercel frontend URL here
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]

# --- Business Rules ---
WORK_START_HOUR=9
WORK_START_MINUTE=30
FULL_DAY_HOURS=8
HALF_DAY_HOURS=4
ANNUAL_LEAVE_BALANCE=12
SICK_LEAVE_BALANCE=6
PERSONAL_LEAVE_BALANCE=3
TAX_RATE=0.10

# --- Rate Limiting ---
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_MINUTES=15

# --- Admin Seed ---
ADMIN_EMAIL=admin@hrnexus.com
ADMIN_PASSWORD=Admin@123456
