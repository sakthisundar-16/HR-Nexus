# ============================================================
# HR Nexus Frontend — Environment Variables
# ============================================================
# Copy this to .env.local for local dev (optional, proxy handles it).
# On Vercel, set VITE_API_URL as an Environment Variable in the project settings.
# ============================================================

# The full base URL of your Render backend API (including /api/v1)
# Example: https://hr-nexus-api.onrender.com/api/v1
VITE_API_URL=https://your-render-app.onrender.com/api/v1
